NODE_ENV=test
JWT_SECRET=test-jwt-secret
COOKIE_SECRET=test-cookie-secret

# Optional: dedicated local Postgres/Redis for HTTP integration tests.
# Start with: npm run test:integration:http:services
# (uses podman compose -f docker-compose.test.yml up -d --wait)
# DATABASE_URL=postgres://postgres:postgres@localhost:5433/medusa_integration_test
# REDIS_URL=redis://localhost:6380

# If DATABASE_URL is unset here, tests inherit DATABASE_URL from .env and
# integration-tests/setup.js derives DB_HOST/DB_USERNAME/DB_PASSWORD for pg-god.

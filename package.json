{
  "name": "@dragonspurr/shopadmin",
  "version": "0.0.1",
  "description": "Dragon's Purr Shop Admin",
  "author": "Medusa (https://medusajs.com)",
  "license": "MIT",
  "keywords": [
    "sqlite",
    "postgres",
    "typescript",
    "ecommerce",
    "headless",
    "medusa"
  ],
  "scripts": {
    "build": "medusa build",
    "start": "sh scripts/start-production.sh",
    "dev": "medusa develop",
    "seed": "medusa exec src/scripts/seed.ts",
    "createUser": "medusa exec src/scripts/create-user.ts",
    "resetAdminPassword": "medusa exec src/scripts/reset-admin-password.ts",
    "fixS3PublicUrls": "medusa exec src/scripts/fix-s3-public-urls.ts",
    "cleanupOrphanDefaultStores": "medusa exec src/scripts/cleanup-orphan-default-stores.ts",
    "test:integration:http": "TEST_TYPE=integration:http NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:integration:http:services": "podman compose -f docker-compose.test.yml up -d --wait && TEST_DATABASE_URL=postgres://postgres:postgres@localhost:5433/medusa_integration_test TEST_REDIS_URL=redis://localhost:6380 npm run test:integration:http",
    "test:integration:http:services:down": "podman compose -f docker-compose.test.yml down -v",
    "test:integration:modules": "TEST_TYPE=integration:modules NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:unit": "TEST_TYPE=unit NODE_OPTIONS=--experimental-vm-modules jest --silent --runInBand --forceExit",
    "test": "npm run test:unit && npm run test:integration:modules && npm run test:integration:http"
  },
  "dependencies": {
    "@medusajs/admin-sdk": "2.15.5",
    "@medusajs/admin-shared": "2.15.5",
    "@medusajs/caching": "2.15.5",
    "@medusajs/cli": "2.15.5",
    "@medusajs/dashboard": "2.15.5",
    "@medusajs/draft-order": "2.15.5",
    "@medusajs/framework": "2.15.5",
    "@medusajs/medusa": "2.15.5",
    "@medusajs/payment-stripe": "2.15.5",
    "@medusajs/ui": "4.1.15",
    "@react-email/components": "npm:react-email@^6.5.0",
    "@tanstack/react-query": "5.64.2",
    "@webbers/mailgun-notification-medusa": "^1.1.2",
    "jwt-decode": "^4.0.0",
    "mailgun.js": "^12.9.0",
    "react-i18next": "13.5.0",
    "react-router-dom": "6.30.3",
    "zod": "4.2.0"
  },
  "devDependencies": {
    "@medusajs/test-utils": "2.15.5",
    "@swc/core": "^1.15.40",
    "@swc/jest": "^0.2.36",
    "@types/jest": "^29.5.13",
    "@types/node": "^20.12.11",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.2.25",
    "jest": "^30.4.2",
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2",
    "vite": "^6.4.2"
  },
  "overrides": {
    "@opentelemetry/exporter-prometheus": "^0.218.0",
    "@opentelemetry/sdk-node": "^0.218.0",
    "ajv": "^8.18.0",
    "esbuild": "^0.25.0",
    "i18next-http-backend": "^3.0.5",
    "lodash": "^4.18.1",
    "protobufjs": "^8.6.0",
    "vite": "^6.4.2"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@10.9.2"
}
